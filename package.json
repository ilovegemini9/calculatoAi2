{
  "name": "workspace",
  "version": "0.0.0",
  "private": true,
  "license": "MIT",
  "packageManager": "pnpm@10.15.0",
  "engines": {
    "node": "22.x"
  },
  "scripts": {
    "dev": "pnpm --filter @workspace/calculator-platform dev",
    "build": "pnpm -r build",
    "typecheck:libs": "tsc --build",
    "typecheck": "pnpm run typecheck:libs && pnpm -r typecheck",
    "lint": "pnpm -r lint"
  },
  "workspaces": [
    "artifacts/*",
    "lib/*",
    "lib/integrations/*",
    "scripts"
  ],
  "dependencies": {
    "@google/genai": "^2.12.0",
    "@replit/connectors-sdk": "^0.4.1"
  },
  "devDependencies": {
    "prettier": "^3.9.4",
    "typescript": "~5.9.3"
  },
  "pnpm": {
    "onlyBuiltDependencies": ["@google/genai", "esbuild", "protobufjs", "sharp", "unrs-resolver"]
  }
}
